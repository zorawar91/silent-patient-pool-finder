# Copy this to .env and fill in your values
# .env is gitignored — never commit real credentials

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sppf
POSTGRES_USER=sppf
POSTGRES_PASSWORD=sppf_local

# Number of synthetic patients to generate (start small: 500–2000)
SYNTHEA_PATIENT_COUNT=1000
SYNTHEA_STATE=Massachusetts
