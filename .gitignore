# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
venv/
.venv/
env/

# Generated data — raw caches are regenerated by the ingest scripts and
# stay out of git. SCORED outputs are committed so a fresh clone (and
# Streamlit Cloud) gets a working dashboard with zero setup.
data/synthetic/
data/models/
data/open/
data/scored/*.csv
data/scored/scores.parquet
data/scored/scores_long.parquet

# Streamlit — ship the theme config, never the secrets
.streamlit/*
!.streamlit/config.toml
!.streamlit/secrets.toml.example

# macOS
.DS_Store

# IDE
.vscode/
.idea/
*.swp

# Jupyter
.ipynb_checkpoints/

# Secrets / env
.env
*.key
.streamlit/secrets.toml

# Local backup copies of decks/docs — never publish
*.backup.*
