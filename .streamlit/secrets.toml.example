# .streamlit/secrets.toml
# Copy this file to .streamlit/secrets.toml and fill in your Neon connection string.
# secrets.toml is gitignored — never commit it.
#
# Get your connection string from:
#   neon.tech → your project → Connection Details → Connection string
# It looks like:
#   postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb

NEON_DATABASE_URL = "postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb"
